{
  "name": "@sadamdi/kaneo-mcp",
  "version": "0.2.0",
  "description": "MCP server covering the full Kaneo API — projects, tasks, columns, labels, comments, time entries, notifications, search, and GitHub/Gitea/Discord/Slack/webhook integrations. Supports API key or browser device-flow auth, with an interactive installer for Cursor, Claude Desktop, and Claude Code.",
  "type": "module",
  "bin": {
    "kaneo-mcp": "dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sadamdi/kaneo-mcp.git"
  },
  "homepage": "https://github.com/Sadamdi/kaneo-mcp",
  "keywords": ["mcp", "model-context-protocol", "kaneo", "project-management"],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js serve",
    "prepublishOnly": "npm run build"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.10.0"
  }
}
